{
  "expo": {
    "name": "Foretera",
    "slug": "quell",
    "version": "0.1.0",
    "icon": "./assets/icon.png",
    "orientation": "default",
    "scheme": "quell",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0C0C0E",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bryanbabb.quell",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.bryanbabb.quell",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0C0C0E"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      "expo-font",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Foretera uses your photos to set a profile picture."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 300,
          "backgroundColor": "#0C0C0E",
          "resizeMode": "contain"
        }
      ],
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "PORTRAIT_UP"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "89031ab0-a5d3-4a44-acab-134069bd0f1e"
      }
    }
  }
}
