{
  "expo": {
    "name": "Quell",
    "slug": "quell",
    "version": "0.1.0",
    "orientation": "default",
    "scheme": "quell",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0E1116",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bryanbabb.quell",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.bryanbabb.quell"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0E1116",
          "resizeMode": "contain"
        }
      ],
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "PORTRAIT_UP"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "89031ab0-a5d3-4a44-acab-134069bd0f1e"
      }
    }
  }
}
