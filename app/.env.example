# Copy to .env (gitignored). EXPO_PUBLIC_ vars are inlined into the JS bundle.
#
# Clerk publishable key — must belong to the SAME Clerk instance whose secret
# key the API uses (api/.dev.vars CLERK_SECRET_KEY).
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Base URL of the Worker API. Local wrangler dev defaults to 8787.
# Use your machine's LAN IP (not localhost) when testing on a physical device.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8787
